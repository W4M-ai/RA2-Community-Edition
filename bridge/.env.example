# RA2 Repeater Configuration
# Leave RA2_HOST blank for auto-discovery, or set your repeater's IP
RA2_HOST=
RA2_PORT=23
RA2_USERNAME=lutron
RA2_PASSWORD=integration

# MQTT Broker (default: bundled Mosquitto — no changes needed)
MQTT_HOST=mosquitto
MQTT_PORT=1883

# WebSocket server port (Homey app connects here)
WS_PORT=8080

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
